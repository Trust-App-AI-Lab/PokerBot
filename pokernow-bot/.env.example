# Poker Now Bot Configuration
# Copy this file to .env and fill in your values

# Game URL (required) — create a game at pokernow.com and paste the URL
GAME_URL=https://www.pokernow.com/games/YOUR_GAME_ID

# Bot display name
BOT_NAME=ARIA_Bot

# Preferred seat number (0-9)
SEAT=5

# Starting stack size
STACK=1000

# Set to 'false' to skip auto-seat-request on connect
AUTO_SEAT=true
